{
  "Site": {
    "Name": "site-nyc-01",
    "PodIdentity": null
  },
  "Lease": {
    "Name": "simetra-leader",
    "Namespace": "simetra",
    "RenewIntervalSeconds": 10,
    "DurationSeconds": 15
  },
  "SnmpListener": {
    "BindAddress": "0.0.0.0",
    "Port": 162,
    "CommunityString": "public",
    "Version": "v2c"
  },
  "HeartbeatJob": {
    "IntervalSeconds": 15
  },
  "CorrelationJob": {
    "IntervalSeconds": 30
  },
  "Liveness": {
    "GraceMultiplier": 2.0
  },
  "Channels": {
    "BoundedCapacity": 100
  },
  "Devices": [
    {
      "Name": "router-core-1",
      "IpAddress": "10.0.1.1",
      "DeviceType": "router",
      "MetricPolls": [
        {
          "MetricName": "simetra_cpu",
          "MetricType": "Gauge",
          "Oids": [
            {
              "Oid": "1.3.6.1.4.1.9999.1.3.1.0",
              "PropertyName": "cpu_utilization",
              "Role": "Metric"
            }
          ],
          "IntervalSeconds": 30
        },
        {
          "MetricName": "simetra_memory",
          "MetricType": "Gauge",
          "Oids": [
            {
              "Oid": "1.3.6.1.4.1.9999.1.3.2.0",
              "PropertyName": "memory_used_bytes",
              "Role": "Metric"
            },
            {
              "Oid": "1.3.6.1.4.1.9999.1.1.1.0",
              "PropertyName": "hostname",
              "Role": "Label"
            }
          ],
          "IntervalSeconds": 60
        }
      ]
    },
    {
      "Name": "switch-floor-2",
      "IpAddress": "10.0.2.1",
      "DeviceType": "switch",
      "MetricPolls": []
    },
    {
      "Name": "npb-2e-01",
      "IpAddress": "10.0.10.1",
      "DeviceType": "NPB",
      "MetricPolls": [
        {
          "MetricName": "port_rx_octets",
          "MetricType": "Counter",
          "Oids": [
            {
              "Oid": "1.3.6.1.4.1.47477.100.4.2.2.5.1.1.3",
              "PropertyName": "port_rx_octets",
              "Role": "Metric"
            }
          ],
          "IntervalSeconds": 30
        },
        {
          "MetricName": "port_tx_octets",
          "MetricType": "Counter",
          "Oids": [
            {
              "Oid": "1.3.6.1.4.1.47477.100.4.2.2.5.1.1.4",
              "PropertyName": "port_tx_octets",
              "Role": "Metric"
            }
          ],
          "IntervalSeconds": 30
        }
      ]
    }
  ],
  "Otlp": {
    "Endpoint": "http://localhost:4317",
    "ServiceName": "simetra-supervisor"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "EnableConsole": false
  }
}
